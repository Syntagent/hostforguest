# VPS development — copy to .env in development/hostforguest
# Public: https://hostforguest-dev.syntagent.com → Cloudflare → 127.0.0.1:3055

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

HOST=127.0.0.1
PORT=8010

USE_POSTGRESQL=true
POSTGRES_SERVER=localhost
POSTGRES_USER=tourist_guide_user
POSTGRES_PASSWORD=
POSTGRES_DB=tourist_guide_db
POSTGRES_PORT=5440

SECRET_KEY=change-me-dev-only
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Cloudflare dev origin
CORS_ORIGINS=https://hostforguest-dev.syntagent.com,http://127.0.0.1:3055

# Next dev: empty = same-origin /api; Next rewrites to API_PROXY_TARGET
NEXT_PUBLIC_API_URL=
API_PROXY_TARGET=http://127.0.0.1:8010

DEV_LOGIN_SEED_ENABLED=true
DEV_LOGIN_SEED_FORCE=false
BOOKING_COM_MOCK=true

OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

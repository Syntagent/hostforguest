{
  "name": "touristguidelocal",
  "private": true,
  "description": "Local dev: npm run dev -> UI :3055 + API :8000. Do not use Docker api/frontend for coding (see AGENTS.md).",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:8010": "concurrently -k -n api,web -c blue,magenta \"npm run dev:api:8010\" \"npm run dev:frontend\"",
    "dev:api": ".venv/bin/python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:api:8010": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8010",
    "dev:frontend": "npm run dev:3055 --prefix frontend",
    "dev:frontend:3060": "npm run dev:3060 --prefix frontend",
    "docker:db": "docker compose up -d postgres",
    "docker:stop-api": "docker compose stop api frontend",
    "check:ports": "powershell -ExecutionPolicy Bypass -File scripts/check-dev-ports.ps1",
    "test:ci-smoke": "powershell -ExecutionPolicy Bypass -File scripts/ci-smoke-backend.ps1",
    "test:ci-smoke:sh": "bash scripts/ci-smoke-backend.sh",
    "test:e2e:ci": "bash scripts/run-e2e-ci.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "concurrently": "^9.1.2"
  },
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Syntagent/hostforguest.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Syntagent/hostforguest/issues"
  },
  "homepage": "https://github.com/Syntagent/hostforguest#readme"
}

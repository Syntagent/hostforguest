# TouristGuideLocal Environment Configuration
# Copy this file to .env and fill in real values.

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=localhost
PORT=8000

# PostgreSQL
USE_POSTGRESQL=true
POSTGRES_SERVER=localhost
POSTGRES_USER=tourist_guide_user
POSTGRES_PASSWORD=
POSTGRES_DB=tourist_guide_db
POSTGRES_PORT=5434

# Neo4j (optional)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=tourist_guide_neo4j

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=change-me-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated origins, used when ENVIRONMENT != development)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# AI Services (store your keys here, not in code)
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Day planner support app (Vite)
VITE_GOOGLE_MAPS_API_KEY=

# Booking.com Channel Integration
BOOKING_COM_MOCK=true
CHANNEL_WEBHOOK_SECRET=
CHANNEL_ENCRYPTION_KEY=

# Dev Login (development only)
DEV_LOGIN_SEED_ENABLED=true
DEV_LOGIN_SEED_FORCE=false
DEV_LOGIN_SEED_EMAIL=dev@touristguide.local
DEV_LOGIN_SEED_PASSWORD=devlogin123

# Next.js (put in repo root .env; frontend loads parent .env in dev)
# Must match the port of `npm run dev:api` (8000) or `npm run dev:api:8010` (8010)
NEXT_PUBLIC_API_URL=http://localhost:8000

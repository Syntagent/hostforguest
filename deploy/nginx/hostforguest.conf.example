# HostForGuest — nginx reverse proxy (example)
#
# Copy to /etc/nginx/sites-available/hostforguest.conf and symlink into sites-enabled.
# Replace hostforguest.example.com and upstream ports to match your stack.
#
# VPS production (docker-compose.vps-prod.yml): UI 127.0.0.1:3007, API 127.0.0.1:8006
# Default docker compose (--profile docker-api): UI :3001, API :8000
#
# Env (production):
#   NEXT_PUBLIC_API_URL=https://hostforguest.example.com
#   CORS_ORIGINS=https://hostforguest.example.com
#
# TLS: use certbot (certbot --nginx) or terminate TLS in Cloudflare Tunnel instead.

upstream hostforguest_api {
    server 127.0.0.1:8006;
    keepalive 16;
}

upstream hostforguest_ui {
    server 127.0.0.1:3007;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name hostforguest.example.com;

    # Redirect HTTP → HTTPS when TLS is enabled (uncomment after certbot)
    # return 301 https://$host$request_uri;
}

server {
    # listen 443 ssl http2;
    # listen [::]:443 ssl http2;
    listen 80;
    listen [::]:80;
    server_name hostforguest.example.com;

    # ssl_certificate     /etc/letsencrypt/live/hostforguest.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/hostforguest.example.com/privkey.pem;

    client_max_body_size 32m;

    # FastAPI: /api/v1/*, /health, OpenAPI under /api/v1/docs
    location /api {
        proxy_pass http://hostforguest_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    location /health {
        proxy_pass http://hostforguest_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Next.js standalone container
    location / {
        proxy_pass http://hostforguest_ui;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

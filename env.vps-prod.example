# VPS production — copy to .env in production/hostforguest
# Public: https://hostforguest.syntagent.com
# Tunnel: /api → 127.0.0.1:8006 , UI → 127.0.0.1:3007

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

USE_POSTGRESQL=true
POSTGRES_SERVER=postgres
POSTGRES_USER=tourist_guide_user
POSTGRES_PASSWORD=SET_STRONG_PASSWORD
POSTGRES_DB=tourist_guide_db
POSTGRES_PORT=5432
POSTGRES_HOST_AUTH_METHOD=md5

SECRET_KEY=SET_STRONG_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

NEXT_PUBLIC_API_URL=https://hostforguest.syntagent.com
CORS_ORIGINS=https://hostforguest.syntagent.com

FRONTEND_PUBLISH_PORT=3007

DEV_LOGIN_SEED_ENABLED=false
DEV_LOGIN_SEED_FORCE=false
BOOKING_COM_MOCK=true

OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

CHANNEL_WEBHOOK_SECRET=
CHANNEL_ENCRYPTION_KEY=
